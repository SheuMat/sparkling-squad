# Email delivery for the booking & contact forms (Resend).
# Copy this file to .env.local for local dev, and add the same vars in
# Vercel → Project → Settings → Environment Variables for production.

# Required to actually send email. Get one free at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where enquiries and booking requests are sent.
MAIL_TO=contact@sparklingsquad.co.uk

# The "from" address. Until you verify sparklingsquad.co.uk in Resend you can
# use Resend's test sender below. Once verified, switch to your own domain,
# e.g. "Sparkling Squad <noreply@sparklingsquad.co.uk>".
MAIL_FROM=Sparkling Squad <onboarding@resend.dev>
